<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- 
      ============================================
      GÜVENLİK UYARISI: API KEY BURAYA YAZMAYIN!
      ============================================
      
      v1.1.0+ sürümünde API key artık App.config'de tutulmuyor.
      
      API key'i Outlook Ribbon üzerinden kaydedin:
      1. Outlook'u açın
      2. Mail sekmesi ? Gemini Çeviri grubu
      3. API Key metin kutusuna anahtarınızı yapıştırın
      4. Kaydet butonuna basın
      
      API key Windows Registry'de AES-256 ile şifrelenir.
      Konum: HKEY_CURRENT_USER\Software\ZaferBilgisayar\GeminiTranslate
    -->
    
    <!-- 
      Gemini Model Yapılandırması (Opsiyonel)
      
      ? ÖNERİLEN: Model belirtilmezse API'den otomatik algılanır.
      
      Manuel model seçmek isterseniz aşağıdaki satırın comment'ini kaldırın:
      
      Örnek:
      <add key="GeminiModel" value="gemini-1.5-flash" />
      
      Desteklenen modeller:
      - gemini-2.0-flash-exp (en yeni, deneysel - çok hızlı)
      - gemini-1.5-flash (kararlı, hızlı - önerilen)
      - gemini-1.5-pro (gelişmiş, daha yavaş ama en kaliteli)
    -->
    
    <!-- Otomatik model algılama için comment'li bırakın -->
    <!-- <add key="GeminiModel" value="gemini-1.5-flash" /> -->
    
  </appSettings>
</configuration>
